global:
  imageRegistry: quay.io/rhpds

langfuse:
  web:
    image:
      repository: quay.io/rhpds/langfuse
      tag: "3.171.0"
  worker:
    image:
      repository: quay.io/rhpds/langfuse-worker
      tag: "3.171.0"
  salt:
    value: "{{ ocp4_workload_langfuse_tenant_salt }}"
  nextauth:
    secret:
      value: "{{ ocp4_workload_langfuse_tenant_nextauth_secret }}"
    url: "{{ _ocp4_workload_langfuse_tenant_url | default('http://localhost:3000') }}"
  encryptionKey:
    value: "{{ ocp4_workload_langfuse_tenant_encryption_key }}"
  additionalEnv:
    - name: LANGFUSE_INIT_ORG_ID
      value: "{{ ocp4_workload_langfuse_tenant_namespace }}"
    - name: LANGFUSE_INIT_ORG_NAME
      value: "{{ ocp4_workload_langfuse_tenant_namespace }}"
    - name: LANGFUSE_INIT_PROJECT_ID
      value: athena
    - name: LANGFUSE_INIT_PROJECT_NAME
      value: athena
    - name: LANGFUSE_INIT_PROJECT_PUBLIC_KEY
      value: "{{ ocp4_workload_langfuse_tenant_public_key }}"
    - name: LANGFUSE_INIT_PROJECT_SECRET_KEY
      value: "{{ ocp4_workload_langfuse_tenant_secret_key }}"
    - name: LANGFUSE_INIT_USER_EMAIL
      value: "{{ ocp4_workload_langfuse_tenant_admin_email }}"
    - name: LANGFUSE_INIT_USER_NAME
      value: Admin
    - name: LANGFUSE_INIT_USER_PASSWORD
      value: "{{ ocp4_workload_langfuse_tenant_admin_password }}"
  extraInitContainers:
    - name: wait-for-deps
      image: quay.io/rhpds/langfuse:3.171.0
      command: ["sh", "-c"]
      args:
        - |
          echo "Waiting for PostgreSQL..."
          until wget -qO- http://langfuse-postgresql:5432 2>&1 | grep -q ""; do sleep 2; done
          echo "Waiting for ClickHouse..."
          until wget -qO- http://langfuse-clickhouse:8123/ping 2>/dev/null; do sleep 2; done
          echo "Dependencies ready"
  resources:
    requests:
      cpu: 100m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 2Gi
  worker:
    extraInitContainers:
      - name: wait-for-postgres
        image: quay.io/rhpds/langfuse:3.171.0
        command: ["sh", "-c"]
        args:
          - |
            echo "Waiting for PostgreSQL..."
            until wget -qO- http://langfuse-postgresql:5432 2>&1 | grep -q ""; do sleep 2; done
            echo "PostgreSQL ready"
    resources:
      requests:
        cpu: 50m
        memory: 256Mi
      limits:
        cpu: 500m
        memory: 512Mi

postgresql:
  auth:
    username: langfuse
    password: "{{ ocp4_workload_langfuse_tenant_postgres_password }}"
  primary:
    resources:
      requests:
        cpu: 50m
        memory: 128Mi
      limits:
        cpu: 500m
        memory: 256Mi

clickhouse:
  auth:
    password: "{{ ocp4_workload_langfuse_tenant_postgres_password }}"
  resourcesPreset: none
  resources:
    requests:
      cpu: 100m
      memory: 256Mi
    limits:
      cpu: "1"
      memory: 1Gi
  shards: 1
  replicaCount: 1
  zookeeper:
    replicaCount: 1
    resources:
      requests:
        cpu: 25m
        memory: 128Mi
      limits:
        cpu: 250m
        memory: 256Mi

redis:
  auth:
    password: "{{ ocp4_workload_langfuse_tenant_postgres_password }}"
  master:
    resources:
      requests:
        cpu: 25m
        memory: 64Mi
      limits:
        cpu: 250m
        memory: 128Mi

s3:
  auth:
    rootPassword: "{{ ocp4_workload_langfuse_tenant_postgres_password }}"
  resources:
    requests:
      cpu: 25m
      memory: 128Mi
    limits:
      cpu: 250m
      memory: 256Mi
